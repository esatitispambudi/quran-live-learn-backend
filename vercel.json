{
  "version": 2,
  "builds": [
    {
      "src": "src/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "src/server.js"
    }
  ],
  "env": {
    "NODE_ENV": "production",
    "GEMINI_API_KEY": "@gemini_api_key",
    "GEMINI_API_VERSION": "v1beta",
    "GEMINI_MODEL": "gemini-2.5-flash",
    "FRONTEND_URL": "@frontend_url"
  }
}
